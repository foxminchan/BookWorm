{
  "AgentGovernance": {
    "DefaultTrustScore": 500,
    "EnableCircuitBreaker": true,
    "EnableMerkleAudit": true,
    "EnablePromptInjectionDetection": true,
    "EnableRings": true,
    "EnableRogueDetection": true,
    "PolicyPaths": [
      "AI/Governance/Policies/default.yaml",
      "Policies/rating-agent.yaml"
    ],
    "RogueDetectionWindowSize": 20,
    "RogueDetectionZThreshold": 2.5,
    "TrustDecayRate": 10
  },
  "AllowedHosts": "*",
  "Logging": {
    "GlobalLogBuffering": {
      "AutoFlushDuration": "00:00:30",
      "MaxBufferSizeInBytes": 104857600,
      "MaxLogRecordSizeInBytes": 51200,
      "Rules": [
        {
          "EventId": 20101,
          "LogLevel": "Information"
        },
        {
          "CategoryName": "BookWorm.Chassis.CQRS.*",
          "LogLevel": "Debug"
        },
        {
          "CategoryName": "BookWorm.Chassis.AI.*",
          "LogLevel": "Debug"
        }
      ]
    },
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "PerIncomingRequestLogBuffering": {
      "AutoFlushDuration": "00:00:05",
      "Rules": [
        {
          "LogLevel": "Information"
        }
      ]
    },
    "RandomProbabilisticSampler": {
      "Rules": [
        {
          "CategoryName": "BookWorm.*",
          "LogLevel": "Information",
          "Probability": 0.25
        },
        {
          "CategoryName": "Microsoft.AspNetCore.*",
          "LogLevel": "Information",
          "Probability": 0.1
        },
        {
          "CategoryName": "System.*",
          "Probability": 0.1
        }
      ]
    }
  },
  "RateLimiter": {
    "FixedWindowRateLimiter": {
      "PermitLimit": 30,
      "QueueLimit": 0,
      "Window": "00:01:00"
    },
    "TokenBucketRateLimiter": {
      "QueueLimit": 5,
      "ReplenishmentPeriod": "00:00:10",
      "TokenLimit": 30,
      "TokensPerPeriod": 20
    }
  }
}
