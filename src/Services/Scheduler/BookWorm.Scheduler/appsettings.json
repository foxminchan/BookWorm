{
  "AllowedHosts": "*",
  "Logging": {
    "GlobalLogBuffering": {
      "AutoFlushDuration": "00:00:30",
      "MaxBufferSizeInBytes": 104857600,
      "MaxLogRecordSizeInBytes": 51200,
      "Rules": [
        {
          "CategoryName": "BookWorm.Scheduler.Jobs.*",
          "LogLevel": "Debug"
        },
        {
          "CategoryName": "Quartz",
          "LogLevel": "Information"
        }
      ]
    },
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "RandomProbabilisticSampler": {
      "Rules": [
        {
          "CategoryName": "BookWorm.*",
          "LogLevel": "Information",
          "Probability": 0.25
        },
        {
          "CategoryName": "Quartz",
          "LogLevel": "Information",
          "Probability": 0.1
        },
        {
          "CategoryName": "System.*",
          "Probability": 0.1
        }
      ]
    }
  }
}
