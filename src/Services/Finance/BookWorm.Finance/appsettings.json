{
  "AllowedHosts": "*",
  "Logging": {
    "GlobalLogBuffering": {
      "AutoFlushDuration": "00:00:30",
      "MaxBufferSizeInBytes": 104857600,
      "MaxLogRecordSizeInBytes": 51200,
      "Rules": [
        {
          "EventId": 20101,
          "LogLevel": "Information"
        },
        {
          "CategoryName": "BookWorm.Finance.Saga.*",
          "LogLevel": "Debug"
        },
        {
          "CategoryName": "MassTransit",
          "LogLevel": "Information"
        }
      ]
    },
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "PerIncomingRequestLogBuffering": {
      "AutoFlushDuration": "00:00:05",
      "Rules": [
        {
          "LogLevel": "Information"
        }
      ]
    },
    "RandomProbabilisticSampler": {
      "Rules": [
        {
          "CategoryName": "BookWorm.*",
          "LogLevel": "Information",
          "Probability": 0.25
        },
        {
          "CategoryName": "MassTransit",
          "LogLevel": "Information",
          "Probability": 0.1
        },
        {
          "CategoryName": "Microsoft.AspNetCore.*",
          "LogLevel": "Information",
          "Probability": 0.1
        },
        {
          "CategoryName": "System.*",
          "Probability": 0.1
        }
      ]
    }
  },
  "OrderStateMachine": {
    "MaxAttempts": 3,
    "MaxRetryTimeout": "00:30:00"
  }
}
