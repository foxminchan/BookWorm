{
  "AllowedHosts": "*",
  "AgentGovernance": {
    "PolicyPaths": [
      "AI/Governance/Policies/default.yaml",
      "Policies/mcp-tools.yaml"
    ],
    "EnableRings": false,
    "EnablePromptInjectionDetection": false,
    "EnableCircuitBreaker": true,
    "EnableRogueDetection": true,
    "EnableMerkleAudit": true,
    "RogueDetectionWindowSize": 20,
    "RogueDetectionZThreshold": 2.5,
    "DefaultTrustScore": 500,
    "TrustDecayRate": 10
  },
  "Logging": {
    "GlobalLogBuffering": {
      "AutoFlushDuration": "00:00:30",
      "MaxBufferSizeInBytes": 104857600,
      "MaxLogRecordSizeInBytes": 51200,
      "Rules": [
        {
          "EventId": 100,
          "LogLevel": "Information"
        },
        {
          "EventId": 101,
          "LogLevel": "Information"
        }
      ]
    },
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "PerIncomingRequestLogBuffering": {
      "AutoFlushDuration": "00:00:05",
      "Rules": [
        {
          "LogLevel": "Information"
        }
      ]
    }
  },
  "ServerInfo": {
    "Icons": [
      {
        "MimeType": "image/svg+xml",
        "Sizes": ["any"],
        "Src": "https://raw.githubusercontent.com/foxminchan/BookWorm/refs/heads/main/assets/Logo.svg"
      }
    ],
    "Title": "MCP Tools Server",
    "Version": "1.0",
    "WebsiteUrl": "https://bookwormdev.netlify.app/docs/services/mcptools/1.0.0/"
  }
}
