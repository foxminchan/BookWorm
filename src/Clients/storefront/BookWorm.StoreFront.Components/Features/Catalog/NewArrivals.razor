@using Microsoft.AspNetCore.Components.Routing
@using BookWorm.StoreFront.Components.Components

@if (_isLoading || _books.Count > 0)
{
    <section class="container mx-auto px-4 py-16" aria-labelledby="new-arrivals-heading">
        <header class="flex justify-between items-center mb-8">
            <h2 id="new-arrivals-heading" class="text-3xl font-bold" style="color: var(--color-glacier-900)">New
                Arrivals</h2>
            @if (_books.Count > 0)
            {
                <NavLink href="catalog" class="text-sm font-semibold" style="color: var(--color-glacier-600)"
                         Match="NavLinkMatch.All">View all →
                </NavLink>
            }
        </header>

        <LoadingSpinner IsLoading="_isLoading" Message="Loading new arrivals..." />

        @if (!_isLoading && _books.Count > 0)
        {
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                @foreach (var book in _books)
                {
                    <article>
                        <a href="/catalog/@book.Id"
                           class="card bg-base-100 shadow-lg hover:shadow-xl transition-shadow cursor-pointer">
                            <figure class="relative w-full aspect-2/3 bg-(--color-glacier-100)">
                                <img src="@book.ImageUrl" alt="@book.Name" class="w-full h-full object-cover rounded-t-2xl"
                                     loading="lazy"/>
                            </figure>
                            <div class="card-body p-4">
                                <div class="flex items-center gap-1 mb-2">
                                    <span class="text-yellow-400"
                                          aria-label="Rating: @book.AverageRating out of 5">@GetStarRating(book.AverageRating)</span>
                                    <span class="text-xs"
                                          style="color: var(--color-glacier-600)">(@book.TotalReviews)</span>
                                </div>
                                <h3 class="font-semibold mb-1" style="color: var(--color-glacier-900)">@book.Name</h3>
                                <div class="flex items-center gap-2">
                                    <span class="text-lg font-bold"
                                          style="color: var(--color-glacier-900)">$@book.Price</span>
                                    @if (book.PriceSale.HasValue)
                                    {
                                        <span class="text-sm line-through"
                                              style="color: var(--color-glacier-500)">$@book.PriceSale</span>
                                    }
                                </div>
                            </div>
                        </a>
                    </article>
                }
            </div>
        }
    </section>
}

@code {

    private static string GetStarRating(double rating)
    {
        var fullStars = (int)Math.Round(rating);
        return new('★', fullStars);
    }
}
