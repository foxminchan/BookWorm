@using BookWorm.StoreFront.Components.Models
@using BookWorm.StoreFront.Components.Components.Button
@using BookWorm.StoreFront.Components.Components.Image
@using BookWorm.StoreFront.Components.Components.Rating
@using BookWorm.StoreFront.Components.Enums

<article class="card bg-base-100 shadow-lg hover:shadow-xl transition-shadow relative flex flex-col h-full">
    @if (Book.PriceSale.HasValue)
    {
        <div class="badge badge-primary absolute top-4 left-4 z-10">SALE</div>
    }
    <a href="/catalog/@Book.Id" class="cursor-pointer">
        <figure class="relative w-full aspect-square"
                style="min-height: 250px; max-height: 400px; background-color: var(--color-glacier-50);">
            @if (_isImageLoading)
            {
                <div class="absolute inset-0 animate-pulse bg-gradient-to-r from-base-300 via-base-200 to-base-300"></div>
            }
            <Image Src="@Book.ImageUrl"
                   Alt="@Book.Name"
                   ObjectFit="ImageFit.Cover"
                   AdditionalClasses="@($"w-full h-full transition-all duration-300 {(_isImageLoading ? "blur-sm" : "blur-0")}")"
                   Style="object-position: center;"
                   OnLoad="HandleImageLoad" />
        </figure>
    </a>
    <div class="card-body p-4 flex-1 flex flex-col">
        <a href="/catalog/@Book.Id" class="cursor-pointer">
            <h3 class="card-title text-base hover:underline" style="color: var(--color-glacier-900)">@Book.Name</h3>
        </a>
        <div class="my-2">
            <Rating Value="@Book.AverageRating"
                    Size="RatingSize.Small"
                    ShowCount="true"
                    TotalCount="@Book.TotalReviews" />
        </div>
        <div class="flex items-center gap-2 mb-4">
            @if (Book.PriceSale.HasValue)
            {
                <span class="text-xl font-bold"
                      style="color: var(--color-glacier-900)">$@Book.PriceSale.Value.ToString("F2")</span>
                <span class="text-sm line-through"
                      style="color: var(--color-glacier-500)">$@Book.Price.ToString("F2")</span>
            }
            else
            {
                <span class="text-xl font-bold"
                      style="color: var(--color-glacier-900)">$@Book.Price.ToString("F2")</span>
            }
        </div>
        @if (ShowAddToCart)
        {
            @if (Book.Status.Equals("OutOfStock", StringComparison.OrdinalIgnoreCase))
            {
                <Button Disabled="true"
                        Size="ButtonSize.Small"
                        AdditionalClasses="w-full mt-auto">
                    Out of Stock
                </Button>
            }
            else
            {
                <Button OnClick="@(e => HandleAddToCart())"
                        Variant="ButtonVariant.Primary"
                        Size="ButtonSize.Small"
                        AdditionalClasses="w-full mt-auto">
                    Add to Cart
                </Button>
            }
        }
    </div>
</article>

@code
{
    [Parameter]
    [EditorRequired]
    public required Book Book { get; set; }

    [Parameter]
    public bool ShowAddToCart { get; set; } = true;

    [Parameter]
    public Action<Guid>? OnAddToCart { get; set; }

    private bool _isImageLoading;

    private void HandleAddToCart()
    {
        OnAddToCart?.Invoke(Book.Id);
    }

    private async Task HandleImageLoad()
    {
        _isImageLoading = false;
        StateHasChanged();
        await Task.CompletedTask;
    }
}
