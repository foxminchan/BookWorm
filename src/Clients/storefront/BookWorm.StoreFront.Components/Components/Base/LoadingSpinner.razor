@if (IsLoading)
{
    <div class="@ContainerClass">
        <div class="flex flex-col items-center">
            <span class="loading loading-spinner @SpinnerSize" style="color: var(--color-glacier-600);"></span>
            @if (!string.IsNullOrEmpty(Message))
            {
                <p class="mt-4 text-sm" style="color: var(--color-glacier-600);">@Message</p>
            }
        </div>
    </div>
}

@code {
    [Parameter] public bool IsLoading { get; set; }

    [Parameter] public string Message { get; set; } = string.Empty;

    [Parameter] public string SpinnerSize { get; set; } = "loading-lg";

    [Parameter] public string ContainerClass { get; set; } = "flex justify-center items-center py-20";
}
