@using BookWorm.StoreFront.Components.Components.Badge
@using BookWorm.StoreFront.Components.Components.Button

<div class="card bg-base-100 shadow-lg sticky top-4">
    <div class="card-body">
        <h2 class="card-title mb-4">Order Summary</h2>

        <div class="space-y-3">
            <div class="flex justify-between text-sm">
                <span>Items (@TotalItems):</span>
                <span>$@Subtotal.ToString("0.00")</span>
            </div>

            <div class="flex justify-between text-sm">
                <span>Shipping:</span>
                <span class="text-success">FREE</span>
            </div>

            @if (TotalSavings > 0)
            {
                <div class="flex justify-between text-sm text-success">
                    <span>You Save:</span>
                    <span>-$@TotalSavings.ToString("0.00")</span>
                </div>
            }

            <div class="divider my-2"></div>

            <div class="flex justify-between text-lg font-bold">
                <span>Total:</span>
                <span>$@Total.ToString("0.00")</span>
            </div>
        </div>

        <div class="card-actions mt-6">
            <Button OnClick="OnCheckout" AdditionalClasses="btn-block">
                Proceed to Checkout
            </Button>
        </div>

        <!-- Trust Badges -->
        <div class="mt-6 pt-6 border-t space-y-2 text-sm text-gray-600">
            @foreach (var badge in _trustBadges)
            {
                <Badge IconUrl="@badge.IconUrl" Text="@badge.Text" AltText="@badge.AltText" />
            }
        </div>
    </div>
</div>
