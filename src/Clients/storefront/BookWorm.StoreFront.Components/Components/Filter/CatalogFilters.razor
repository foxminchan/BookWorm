<aside class="w-full lg:w-64 lg:shrink-0">
    <div class="lg:sticky lg:top-4 flex flex-col max-h-[calc(100vh-2rem)]">
        <div class="mb-4 hidden lg:block">
            <h2 class="text-xl font-bold" style="color: var(--color-glacier-900)">Filters</h2>
        </div>

        <div class="flex-1 overflow-y-auto space-y-6 pr-2">
            <PriceRangeFilter MinPrice="MinPrice"
                              MaxPrice="MaxPrice"
                              OnMinPriceChanged="OnMinPriceChanged"
                              OnMaxPriceChanged="OnMaxPriceChanged"
                              OnPriceRangeSelected="OnPriceRangeSelected"/>

            <CategoryFilter SelectedCategoryIds="SelectedCategoryIds"
                            OnCategoryToggled="OnCategoryToggled"/>

            <PublisherFilter SelectedPublisherIds="SelectedPublisherIds"
                             OnPublisherToggled="OnPublisherToggled"/>
        </div>

        <div class="mt-4 pt-4 border-t">
            <button @onclick="HandleClearFilters"
                    class="btn btn-outline btn-sm w-full">
                Clear All Filters
            </button>
        </div>
    </div>
</aside>
