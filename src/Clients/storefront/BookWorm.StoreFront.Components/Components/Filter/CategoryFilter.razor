@using BookWorm.StoreFront.Components.Models

@if (_isLoading || Categories.Count > 0)
{
    <CheckboxFilter TItem="Category"
                    Title="Categories"
                    Items="Categories"
                    SelectedIds="SelectedCategoryIds"
                    GetItemId="@(c => c.Id)"
                    GetItemName="@(c => c.Name)"
                    OnToggle="HandleCategoryToggleInternal"
                    IsLoading="_isLoading" />
}
