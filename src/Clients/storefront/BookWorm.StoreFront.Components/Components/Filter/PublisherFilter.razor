@using BookWorm.StoreFront.Components.Models

@if (_isLoading || Publishers.Count > 0)
{
    <CheckboxFilter TItem="Publisher"
                    Title="Publishers"
                    Items="Publishers"
                    SelectedIds="SelectedPublisherIds"
                    GetItemId="@(p => p.Id)"
                    GetItemName="@(p => p.Name)"
                    OnToggle="HandlePublisherToggleInternal"
                    IsLoading="_isLoading" />
}
