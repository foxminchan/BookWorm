@page "/catalog/{id:guid}"
@using BookWorm.StoreFront.Components.Components.Badge
@using BookWorm.StoreFront.Components.Components.Breadcrumb
@using BookWorm.StoreFront.Components.Components.Spinner
@using BookWorm.StoreFront.Components.Components.Image
@using BookWorm.StoreFront.Components.Components.Product
@using BookWorm.StoreFront.Components.Components.QuantitySelector
@using Microsoft.AspNetCore.Components.Sections
@rendermode InteractiveServer

<PageTitle>@(_book?.Name ?? "Product") | BookWorm</PageTitle>
<SectionContent SectionName="page-header-title">@(_book?.Name ?? "Product Details")</SectionContent>
<SectionContent SectionName="page-header-subtitle">@_book?.Category?.Name</SectionContent>

<div class="bg-base-100 min-h-screen">
    <Breadcrumb Items="_breadcrumbItems" />

    @if (_isLoading)
    {
        <div class="container mx-auto px-4 py-8">
            <Spinner IsLoading="true" />
        </div>
    }
    else if (_book is null)
    {
        <div class="container mx-auto px-4 py-8">
            <div class="alert alert-warning">
                <span>Book not found</span>
            </div>
        </div>
    }
    else
    {
        <div class="container mx-auto px-4 py-8">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-12">
                <div class="relative">
                    <div class="sticky top-4">
                        @if (_book.PriceSale.HasValue)
                        {
                            <div class="absolute top-4 left-4 z-10">
                                <Badge Text="SALE" TextClass="badge badge-primary text-lg px-4 py-3" />
                            </div>
                        }
                        <figure class="relative w-full bg-white rounded-lg shadow-lg overflow-hidden"
                                style="aspect-ratio: 3/4; max-height: 600px;">
                            <Image Src="@_book.ImageUrl"
                                   Alt="@_book.Name"
                                   AdditionalClasses="w-full h-full" />
                        </figure>
                    </div>
                </div>
                <div class="flex flex-col">
                    <ProductInfo Book="@_book" />
                    <QuantitySelector @bind-Quantity="_quantity"
                                     IsOutOfStock="@_book.Status.Equals("OutOfStock", StringComparison.OrdinalIgnoreCase)"
                                     OnAddToCartClick="@AddToCart" />
                    <div class="flex flex-wrap gap-4 mb-6">
                        <Badge IconUrl="box"
                               Text="Free Shipping"
                               AltText="Shipping"
                               IconStyle="color: var(--color-glacier-700)"
                               TextStyle="color: var(--color-glacier-700)" />
                        @if (_book.Status.Equals("OutOfStock", StringComparison.OrdinalIgnoreCase))
                        {
                            <Badge IconUrl="x-circle"
                                   Text="Out of Stock"
                                   AltText="Out of Stock"
                                   TextClass="text-error" />
                        }
                        else
                        {
                            <Badge IconUrl="check-circle"
                                   Text="In Stock"
                                   AltText="In Stock"
                                   TextClass="text-success" />
                        }
                    </div>
                    <div class="border-t pt-6" style="border-color: var(--color-glacier-300)">
                        <dl class="space-y-3">
                            @if (_book.Publisher is not null)
                            {
                                <div class="flex">
                                    <dt class="font-semibold w-32" style="color: var(--color-glacier-700)">Publisher:</dt>
                                    <dd style="color: var(--color-glacier-900)">
                                        <a href="catalog?category=@_book.Publisher.Id" class="hover:underline">@_book.Publisher.Name</a>
                                    </dd>
                                </div>
                            }
                            @if (_book.Category is not null)
                            {
                                <div class="flex">
                                    <dt class="font-semibold w-32" style="color: var(--color-glacier-700)">Category:</dt>
                                    <dd style="color: var(--color-glacier-900)">
                                        <a href="catalog?category=@_book.Category.Id" class="hover:underline">@_book.Category.Name</a>
                                    </dd>
                                </div>
                            }
                        </dl>
                    </div>
                </div>
            </div>
            <ProductTabs @bind-ActiveTab="_activeTab"
                        Description="@_book.Description"
                        TotalReviews="@_book.TotalReviews"
                        BookId="@_book.Id"
                        BookName="@_book.Name" />
        </div>
    }
</div>
