@page "/catalog"
@using BookWorm.StoreFront.Components.Components.Breadcrumb
@using BookWorm.StoreFront.Components.Components.EmptyState
@using BookWorm.StoreFront.Components.Components.Filter
@using BookWorm.StoreFront.Components.Components.Spinner
@using BookWorm.StoreFront.Components.Components.Other
@using BookWorm.StoreFront.Components.Components.Pagination
@using BookWorm.StoreFront.Components.Components.Product
@using Microsoft.AspNetCore.Components.Sections
@rendermode InteractiveServer

<PageTitle>Catalog | BookWorm</PageTitle>
<SectionContent SectionName="page-header-title">Catalog</SectionContent>
<SectionContent SectionName="page-header-subtitle">Explore Our Extensive Collection of Books</SectionContent>

<div class="bg-base-100 min-h-screen">
    <Breadcrumb Items="_breadcrumbItems"/>

    <section class="container mx-auto px-4 py-8">
        <div class="lg:flex lg:gap-8">
            <!-- Mobile Filter Toggle Button -->
            <div class="lg:hidden mb-4">
                <button @onclick="ToggleFilters"
                        class="btn btn-outline btn-sm w-full">
                    <img src="/icons/filter.svg" alt="Filter" class="h-5 w-5 mr-2" loading="lazy"/>
                    Filters
                </button>
            </div>

            <!-- Filters Sidebar -->
            <div class="@(_showFilters ? "block" : "hidden") lg:block @(_showFilters ? "fixed inset-0 z-50 bg-base-100 overflow-y-auto p-4 lg:relative lg:p-0 lg:bg-transparent" : "")">
                @if (_showFilters)
                {
                    <div class="lg:hidden flex justify-between items-center mb-4">
                        <h2 class="text-xl font-bold" style="color: var(--color-glacier-900)">Filters</h2>
                        <button @onclick="ToggleFilters" class="btn btn-ghost btn-sm btn-circle">
                            <img src="/icons/close.svg" alt="Close" class="h-6 w-6" loading="lazy"/>
                        </button>
                    </div>
                }
                <CatalogFilters MinPrice="_filters.MinPrice"
                                MaxPrice="_filters.MaxPrice"
                                SelectedCategoryIds="new HashSet<Guid>(_filters.CategoryId ?? [])"
                                SelectedPublisherIds="new HashSet<Guid>(_filters.PublisherId ?? [])"
                                OnMinPriceChanged="OnMinPriceChange"
                                OnMaxPriceChanged="OnMaxPriceChange"
                                OnPriceRangeSelected="OnPriceRangeSelected"
                                OnCategoryToggled="OnCategoryToggled"
                                OnPublisherToggled="OnPublisherToggled"
                                OnClearFilters="ClearFilters"/>
            </div>

            <!-- Main Content -->
            <main class="flex-1 w-full">
                <CatalogHeader FilteredCount="_filteredBooks.Count"
                               TotalCount="_totalBooks"
                               CurrentSortBy="@GetSortByValue()"
                               CurrentSortByChanged="OnSortChanged"
                               OnSortChanged="ApplyFilters"/>

                <Spinner IsLoading="_isLoading"/>

                @if (!_isLoading && _filteredBooks.Count > 0)
                {
                    <div class="grid grid-cols-2 md:grid-cols-2 xl:grid-cols-3 gap-6">
                        @foreach (var book in _filteredBooks)
                        {
                            <ProductCard Book="book" OnAddToCart="AddToCart"/>
                        }
                    </div>

                    <Pagination CurrentPage="_filters.PageIndex"
                                TotalPages="_totalPages"
                                OnPageChanged="ChangePage"/>
                }
                else
                {
                    <EmptyState OnClearFilters="ClearFilters"/>
                }
            </main>
        </div>
    </section>
</div>
