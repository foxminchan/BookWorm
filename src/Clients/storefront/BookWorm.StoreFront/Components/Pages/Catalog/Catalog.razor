        _allBooks =
        [
            new Book(
                Guid.NewGuid(),
                "Professional Drone",
                "4K camera with 30-minute flight time",
                "https://images.unsplash.com/photo-1508614999368-9260051292e5?w=400",
                399.99m,
                499.99m,
                "Available",
                new Category(Guid.NewGuid(), "Electronics"),
                new Publisher(Guid.NewGuid(), "Apple Inc."),
                [new Author(Guid.NewGuid(), "Tech Author")],
                4.5,
                218
            ),
            new Book(
                Guid.NewGuid(),
                "Digital Camera",
                "24MP with 4K video recording",
                "https://images.unsplash.com/photo-1516035069371-29a1b244cc32?w=400",
                349.99m,
                null,
                "Available",
                new Category(Guid.NewGuid(), "Electronics"),
                new Publisher(Guid.NewGuid(), "Samsung (54)"),
                [new Author(Guid.NewGuid(), "Camera Expert")],
                4.0,
                95
            ),
            new Book(
                Guid.NewGuid(),
                "Mechanical Keyboard",
                "Blue switches with RGB lighting",
                "https://images.unsplash.com/photo-1587829741301-dc798b83add3?w=400",
                129.99m,
                null,
                "Available",
                new Category(Guid.NewGuid(), "Accessories"),
                new Publisher(Guid.NewGuid(), "Google (37)"),
                [new Author(Guid.NewGuid(), "Keyboard Pro")],
                4.8,
                142
            ),
            new Book(
                Guid.NewGuid(),
                "Travel Backpack",
                "Water resistant with laptop compartment",
                "https://images.unsplash.com/photo-1553062407-98eeb64c6a62?w=400",
                59.99m,
                79.99m,
                "Available",
                new Category(Guid.NewGuid(), "Accessories"),
                new Publisher(Guid.NewGuid(), "Sony (48)"),
                [new Author(Guid.NewGuid(), "Travel Writer")],
                4.6,
                324
            ),
            new Book(
                Guid.NewGuid(),
                "Indoor Plant",
                "Low maintenance air purifying plant",
                "https://images.unsplash.com/photo-1509937528035-ad76254b0356?w=400",
                34.99m,
                null,
                "Available",
                new Category(Guid.NewGuid(), "Home & Garden"),
                new Publisher(Guid.NewGuid(), "Apple Inc."),
                [new Author(Guid.NewGuid(), "Botanist")],
                4.2,
                87
            ),
            new Book(
                Guid.NewGuid(),
                "Smart Speaker",
                "Voice control with premium sound",
                "https://images.unsplash.com/photo-1608043152269-423dbba4e7e1?w=400",
                99.99m,
                129.99m,
                "Available",
                new Category(Guid.NewGuid(), "Electronics"),
                new Publisher(Guid.NewGuid(), "Samsung (54)"),
                [new Author(Guid.NewGuid(), "Audio Expert")],
                4.4,
                203
            ),
            new Book(
                Guid.NewGuid(),
                "Premium Headphones",
                "Noise cancelling with 30-hour battery",
                "https://images.unsplash.com/photo-1505740420928-5e560c06d30e?w=400",
                149.99m,
                199.99m,
                "Available",
                new Category(Guid.NewGuid(), "Electronics"),
                new Publisher(Guid.NewGuid(), "Sony (48)"),
                [new Author(Guid.NewGuid(), "Sound Engineer")],
                4.7,
                512
            ),
            new Book(
                Guid.NewGuid(),
                "Athletic Sneakers",
                "Lightweight with cushioned support",
                "https://images.unsplash.com/photo-1542291026-7eec264c27ff?w=400",
                89.99m,
                119.99m,
                "Available",
                new Category(Guid.NewGuid(), "Fashion"),
                new Publisher(Guid.NewGuid(), "Google (37)"),
                [new Author(Guid.NewGuid(), "Sports Expert")],
                4.3,
                876
            ),
            new Book(
                Guid.NewGuid(),
                "Premium Coffee Maker",
                "12-cup capacity with programmable timer",
                "https://images.unsplash.com/photo-1517668808822-9ebb02f2a0e6?w=400",
                79.99m,
                null,
                "Available",
                new Category(Guid.NewGuid(), "Home & Kitchen"),
                new Publisher(Guid.NewGuid(), "Apple Inc."),
                [new Author(Guid.NewGuid(), "Coffee Expert")],
                4.5,
                342
            )
        ];

        _totalBooks = _allBooks.Count;

        // Initialize publisher filters
        _availablePublishers =
        [
            new PublisherFilter(Guid.NewGuid(), "Apple Inc.", 87),
            new PublisherFilter(Guid.NewGuid(), "Samsung (54)", 54),
            new PublisherFilter(Guid.NewGuid(), "Google (37)", 37),
            new PublisherFilter(Guid.NewGuid(), "Sony (48)", 48)
        ];
    }

    private void ApplyFilters()
    {
        _filteredBooks = _allBooks;

        // Apply price filter
        if (_filters.MinPrice.HasValue)
        {
            _filteredBooks = _filteredBooks.Where(b => b.Price >= _filters.MinPrice.Value).ToList();
        }
        if (_filters.MaxPrice.HasValue)
        {
            _filteredBooks = _filteredBooks.Where(b => b.Price <= _filters.MaxPrice.Value).ToList();
        }

        // Apply publisher filter
        if (_filters.PublisherIds.Count > 0)
        {
            _filteredBooks = _filteredBooks.Where(b => b.Publisher != null && _filters.PublisherIds.Contains(b.Publisher.Id)).ToList();
        }

        // Apply sorting
        _filteredBooks = _filters.SortBy switch
        {
            "price-low" => _filteredBooks.OrderBy(b => b.Price).ToList(),
            "price-high" => _filteredBooks.OrderByDescending(b => b.Price).ToList(),
            "name-asc" => _filteredBooks.OrderBy(b => b.Name).ToList(),
            "name-desc" => _filteredBooks.OrderByDescending(b => b.Name).ToList(),
            "rating" => _filteredBooks.OrderByDescending(b => b.AverageRating).ToList(),
            "reviews" => _filteredBooks.OrderByDescending(b => b.TotalReviews).ToList(),
            _ => _filteredBooks
        };

        // Calculate pagination
        _totalPages = (int)Math.Ceiling(_filteredBooks.Count / (double)_filters.PageSize);
        var skip = (_filters.PageIndex - 1) * _filters.PageSize;
        _filteredBooks = _filteredBooks.Skip(skip).Take(_filters.PageSize).ToList();
    }

    private void ToggleSection(FilterSection section)
    {
        if (!_expandedSections.Add(section))
        {
            _expandedSections.Remove(section);
        }

        StateHasChanged();
    }

    private void TogglePublisher(Guid publisherId, bool isChecked)
    {
        if (isChecked)
        {
            _filters.PublisherIds.Add(publisherId);
        }
        else
        {
            _filters.PublisherIds.Remove(publisherId);
        }
        ApplyFilters();
    }

    private void OnMinPriceChange(decimal value)
    {
        if (value <= (_filters.MaxPrice ?? 500))
        {
            _filters.MinPrice = value == 0 ? null : value;
            ApplyFilters();
        }
    }

    private void OnMaxPriceChange(decimal value)
    {
        if (value >= (_filters.MinPrice ?? 0))
        {
            _filters.MaxPrice = value == 500 ? null : value;
            ApplyFilters();
        }
    }

    private void SetPriceRange(decimal? min, decimal? max)
    {
        _filters.MinPrice = min;
        _filters.MaxPrice = max;
        ApplyFilters();
    }

    private void ClearFilters()
    {
        _filters = new CatalogFilters();
        ApplyFilters();
    }

    private void ChangePage(int page)
    {
        if (page >= 1 && page <= _totalPages)
        {
            _filters.PageIndex = page;
            ApplyFilters();
        }
    }

    private void AddToCart(Guid bookId)
    {
        // TODO: Implement add to cart functionality
        Console.WriteLine($"Added book {bookId} to cart");
    }

    private sealed class CatalogFilters
    {
        public int PageIndex { get; set; } = 1;
        public int PageSize { get; set; } = 9;
        public decimal? MinPrice { get; set; }
        public decimal? MaxPrice { get; set; }
        public HashSet<Guid> PublisherIds { get; set; } = [];
        public string SortBy { get; set; } = "price-low";
    }

    private sealed record PublisherFilter(Guid Id, string Name, int Count);
}
