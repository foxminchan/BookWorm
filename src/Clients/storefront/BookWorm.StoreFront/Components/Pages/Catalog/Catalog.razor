@page "/catalog"
@using BookWorm.StoreFront.Components.Components.Base
@using BookWorm.StoreFront.Components.Components.Catalog
@using BookWorm.StoreFront.Components.Models
@using BookWorm.StoreFront.Components.Mocks
@using Microsoft.AspNetCore.Components.Sections
@rendermode InteractiveServer

<PageTitle>Catalog | BookWorm</PageTitle>
<SectionContent SectionName="page-header-title">Catalog</SectionContent>
<SectionContent SectionName="page-header-subtitle">Explore Our Extensive Collection of Books</SectionContent>

<div class="bg-base-100 min-h-screen">
    <Breadcrumb Items="_breadcrumbItems" />

    <div class="container mx-auto px-4 py-8">
        <div class="flex gap-8">
            <!-- Filters Sidebar -->
            <CatalogFilters MinPrice="_filters.MinPrice"
                           MaxPrice="_filters.MaxPrice"
                           SelectedPublisherIds="_filters.PublisherIds"
                           AvailablePublishers="_availablePublishers"
                           OnMinPriceChanged="OnMinPriceChange"
                           OnMaxPriceChanged="OnMaxPriceChange"
                           OnPriceRangeSelected="OnPriceRangeSelected"
                           OnPublisherToggled="OnPublisherToggled"
                           OnClearFilters="ClearFilters" />

            <!-- Main Content -->
            <main class="flex-1">
                <!-- Header with View Toggle and Sort -->
                <div class="flex justify-between items-center mb-6">
                    <p class="text-sm" style="color: var(--color-glacier-600)">
                        Showing @_filteredBooks.Count of @_totalBooks products
                    </p>
                    <div class="flex items-center gap-4">
                        <!-- Sort Dropdown -->
                        <select @bind="_filters.SortBy"
                                @bind:after="ApplyFilters"
                                class="select select-bordered select-sm"
                                style="width: 180px">
                            <option value="price-low">Price: Low to High</option>
                            <option value="price-high">Price: High to Low</option>
                            <option value="name-asc">Name: A to Z</option>
                            <option value="name-desc">Name: Z to A</option>
                            <option value="rating">Rating</option>
                            <option value="reviews">Most Reviews</option>
                        </select>
                    </div>
                </div>

                <!-- Products Grid -->
                <LoadingSpinner IsLoading="_isLoading" />

                @if (!_isLoading && _filteredBooks.Count > 0)
                {
                    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
                        @foreach (var book in _filteredBooks)
                        {
                            <ProductCard Book="book" OnAddToCart="AddToCart" />
                        }
                    </div>

                    <Pagination CurrentPage="_filters.PageIndex"
                               TotalPages="_totalPages"
                               OnPageChanged="ChangePage" />
                }
                else
                {
                    <EmptyState OnClearFilters="ClearFilters" />
                }
            </main>
        </div>
    </div>
</div>

@code {
    private readonly List<Breadcrumb.BreadcrumbItem> _breadcrumbItems =
    [
        new("Home", "/"),
        new("Catalog")
    ];

    private CatalogFiltersModel _filters = new();
    private List<Book> _allBooks = [];
    private List<Book> _filteredBooks = [];
    private int _totalBooks;
    private int _totalPages;
    private bool _isLoading = true;

    private List<Publisher> _availablePublishers = [];

    protected override async Task OnInitializedAsync()
    {
        _isLoading = true;
        InitializeMockData();
        ApplyFilters();
        _isLoading = false;
        await base.OnInitializedAsync();
    }

    private void InitializeMockData()
    {
        _allBooks = MockDataProvider.GetAllBooks();
        _totalBooks = _allBooks.Count;
        _availablePublishers = MockDataProvider.GetPublishers();
    }

    private void ApplyFilters()
    {
        _filteredBooks = _allBooks;

        // Apply price filter
        if (_filters.MinPrice.HasValue)
        {
            _filteredBooks = _filteredBooks.Where(b => b.Price >= _filters.MinPrice.Value).ToList();
        }
        if (_filters.MaxPrice.HasValue)
        {
            _filteredBooks = _filteredBooks.Where(b => b.Price <= _filters.MaxPrice.Value).ToList();
        }

        // Apply publisher filter
        if (_filters.PublisherIds.Count > 0)
        {
            _filteredBooks = _filteredBooks.Where(b => b.Publisher is not null && _filters.PublisherIds.Contains(b.Publisher.Id)).ToList();
        }

        // Apply sorting
        _filteredBooks = _filters.SortBy switch
        {
            "price-low" => _filteredBooks.OrderBy(b => b.Price).ToList(),
            "price-high" => _filteredBooks.OrderByDescending(b => b.Price).ToList(),
            "name-asc" => _filteredBooks.OrderBy(b => b.Name).ToList(),
            "name-desc" => _filteredBooks.OrderByDescending(b => b.Name).ToList(),
            "rating" => _filteredBooks.OrderByDescending(b => b.AverageRating).ToList(),
            "reviews" => _filteredBooks.OrderByDescending(b => b.TotalReviews).ToList(),
            _ => _filteredBooks
        };

        // Calculate pagination
        _totalPages = (int)Math.Ceiling(_filteredBooks.Count / (double)_filters.PageSize);
        var skip = (_filters.PageIndex - 1) * _filters.PageSize;
        _filteredBooks = _filteredBooks.Skip(skip).Take(_filters.PageSize).ToList();
    }

    private void OnPublisherToggled((Guid PublisherId, bool IsChecked) args)
    {
        if (args.IsChecked)
        {
            _filters.PublisherIds.Add(args.PublisherId);
        }
        else
        {
            _filters.PublisherIds.Remove(args.PublisherId);
        }
        ApplyFilters();
    }

    private void OnMinPriceChange(decimal? value)
    {
        if (!value.HasValue || value.Value <= (_filters.MaxPrice ?? 9999))
        {
            _filters.MinPrice = value;
            ApplyFilters();
        }
    }

    private void OnMaxPriceChange(decimal? value)
    {
        if (!value.HasValue || value.Value >= (_filters.MinPrice ?? 0))
        {
            _filters.MaxPrice = value;
            ApplyFilters();
        }
    }

    private void OnPriceRangeSelected((decimal? Min, decimal? Max) range)
    {
        _filters.MinPrice = range.Min;
        _filters.MaxPrice = range.Max;
        ApplyFilters();
    }

    private void ClearFilters()
    {
        _filters = new();
        ApplyFilters();
    }

    private void ChangePage(int page)
    {
        if (page >= 1 && page <= _totalPages)
        {
            _filters.PageIndex = page;
            ApplyFilters();
        }
    }

    private void AddToCart(Guid bookId)
    {
        // TODO: Implement add to cart functionality
        Console.WriteLine($"Added book {bookId} to cart");
    }

    private sealed class CatalogFiltersModel
    {
        public int PageIndex { get; set; } = 1;
        public int PageSize { get; set; } = 9;
        public decimal? MinPrice { get; set; }
        public decimal? MaxPrice { get; set; }
        public HashSet<Guid> PublisherIds { get; set; } = [];
        public string SortBy { get; set; } = "price-low";
    }
}
