@page "/basket"
@using BookWorm.StoreFront.Components.Models
@using BookWorm.StoreFront.Components.Mocks
@using BookWorm.StoreFront.Components.Components.Base
@using BookWorm.StoreFront.Components.Components.Basket
@using Microsoft.AspNetCore.Components.Sections
@rendermode InteractiveServer

<PageTitle>Shopping Basket | BookWorm</PageTitle>
<SectionContent SectionName="page-header-title">Shopping Basket</SectionContent>
<SectionContent SectionName="page-header-subtitle">Review Your Selected Items</SectionContent>

<div class="container mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-8">Shopping Basket</h1>

    @if (_isLoading)
    {
        <LoadingSpinner IsLoading="true" Message="Loading your basket..." />
    }
    else if (_basket?.Items is null || !_basket.Items.Any())
    {
        <div class="text-center py-12">
            <div class="text-6xl mb-4">🛒</div>
            <h2 class="text-2xl font-semibold mb-2">Your basket is empty</h2>
            <p class="text-gray-600 mb-6">Add some books to get started!</p>
            <a href="/" class="btn btn-primary" style="background-color: var(--color-glacier-600)">Continue Shopping</a>
        </div>

    }
    else
    {
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Basket Items -->
            <div class="lg:col-span-2">
                <div class="space-y-4">
                    @foreach (var item in _basket.Items)
                    {
                        <BasketItemCard
                            Item="@item"
                            OnIncrease="@(() => IncreaseQuantity(item.Id!))"
                            OnDecrease="@(() => DecreaseQuantity(item.Id!))"
                            OnRemove="@(() => RemoveItem(item.Id!))" />
                    }
                </div>

                <!-- Continue Shopping Button -->
                <div class="mt-6">
                    <a href="/" class="btn btn-outline">← Continue Shopping</a>
                </div>
            </div>

            <!-- Order Summary -->
            <div class="lg:col-span-1">
                <OrderSummary
                    TotalItems="@_basket.Items.Sum(i => i.Quantity)"
                    Subtotal="@GetSubtotal()"
                    Total="@GetTotal()"
                    TotalSavings="@GetTotalSavings()"
                    OnCheckout="@ProceedToCheckout" />
            </div>
        </div>
    }
</div>

@code {
    private CustomerBasket? _basket;
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        // Simulate loading delay
        await Task.Delay(500);

        // Load mock basket data
        _basket = MockDataProvider.GetMockBasket();
        _isLoading = false;
    }

    private void IncreaseQuantity(string itemId)
    {
        var item = _basket?.Items.FirstOrDefault(i => i.Id == itemId);
        if (item != null)
        {
            var index = _basket!.Items.IndexOf(item);
            _basket.Items[index] = item with { Quantity = item.Quantity + 1 };
        }
    }

    private void DecreaseQuantity(string itemId)
    {
        var item = _basket?.Items.FirstOrDefault(i => i.Id == itemId);
        if (item != null && item.Quantity > 1)
        {
            var index = _basket!.Items.IndexOf(item);
            _basket.Items[index] = item with { Quantity = item.Quantity - 1 };
        }
    }

    private void RemoveItem(string itemId)
    {
        if (_basket != null)
        {
            var item = _basket.Items.FirstOrDefault(i => i.Id == itemId);
            if (item != null)
            {
                _basket.Items.Remove(item);
            }
        }
    }

    private decimal GetSubtotal()
    {
        return _basket?.Items.Sum(i => (i.PriceSale ?? i.Price) * i.Quantity) ?? 0;
    }

    private decimal GetTotalSavings()
    {
        return _basket?.Items
            .Where(i => i.PriceSale.HasValue)
            .Sum(i => (i.Price - i.PriceSale!.Value) * i.Quantity) ?? 0;
    }

    private decimal GetTotal()
    {
        return GetSubtotal();
    }

    private void ProceedToCheckout()
    {
        // Navigate to checkout page (to be implemented)
        // For now, just show an alert
        Console.WriteLine("Proceeding to checkout...");
    }
}
