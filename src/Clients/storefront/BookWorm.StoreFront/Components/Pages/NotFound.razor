@page "/not-found"
@layout MainLayout

<PageTitle>Page Not Found - BookWorm</PageTitle>

<div class="not-found-container">
    <div class="not-found-content">
        <div class="error-code">404</div>
        <h1>Lost in the Library?</h1>
        <p>Sorry, we couldn't find the page you're looking for. It might have been moved, deleted, or never existed.</p>
        <div class="actions">
            <a href="/" class="btn-primary">
                <FluentIcon Value="@(new Icons.Regular.Size20.Home())" />
                Back to Home
            </a>
        </div>
    </div>
</div>
