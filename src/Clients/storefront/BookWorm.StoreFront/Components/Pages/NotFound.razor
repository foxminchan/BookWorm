@page "/not-found"
@using Microsoft.AspNetCore.Components.Sections
@layout MainLayout

<PageTitle>Not Found | BookWorm</PageTitle>
<SectionContent SectionName="page-header-title">Not Found</SectionContent>
<SectionContent SectionName="page-header-subtitle">Oops! The page you're looking for doesn't exist</SectionContent>

<section class="min-h-screen flex items-center justify-center bg-(--color-glacier-50) px-4">
    <div class="text-center max-w-2xl mx-auto">
        <h1 class="text-4xl font-bold mb-4" style="color: var(--color-glacier-900)">Page not found</h1>
        <p class="text-lg mb-8" style="color: var(--color-glacier-600)">
            We couldn't find the page you were looking for.
        </p>
        <NavLink href="/"
                 Match="NavLinkMatch.All"
                 class="inline-block px-12 py-4 rounded-lg font-semibold text-lg hover:opacity-90 transition-opacity text-white"
                 style="background-color: var(--color-glacier-600)">
            Return Home
        </NavLink>
    </div>
</section>
