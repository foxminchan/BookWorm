@page "/"
@using BookWorm.StoreFront.Components.Features.Catalog
@using Microsoft.AspNetCore.Components.Sections

<PageTitle>Home | BookWorm</PageTitle>
<SectionContent SectionName="page-header-title">Home</SectionContent>
<SectionContent SectionName="page-header-subtitle">Discover Your Next Favorite Book</SectionContent>

<section class="bg-(--color-glacier-50) py-16" aria-labelledby="hero-heading">
    <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">
            <div>
                <h1 id="hero-heading" class="text-5xl font-bold mb-4" style="color: var(--color-glacier-900)">
                    Premium Books for Modern Reading
                </h1>
                <p class="text-lg mb-6" style="color: var(--color-glacier-700)">
                    Discover our curated collection of high-quality books designed to enhance your reading experience.
                </p>
                <a href="catalog" class="btn text-white px-8 py-3 rounded-lg font-semibold"
                   style="background-color: var(--color-glacier-600); border-color: var(--color-glacier-600)">
                    Shop Collection
                </a>
            </div>
            <div class="hidden lg:flex justify-center items-center">
                <img src="@Assets["/images/banner.webp"]" alt="BookWorm Banner" class="w-full max-h-80 rounded-3xl object-contain" loading="lazy" />
            </div>
        </div>
    </div>
</section>

<NewArrivals />

<section class="bg-(--color-glacier-50) py-16" aria-labelledby="featured-heading">
    <div class="container mx-auto px-4">
        <article class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-center">
            <figure class="h-96 bg-(--color-glacier-200) rounded-lg overflow-hidden">
                <img src="@Assets["/images/premium-book-collection.webp"]" alt="Premium Book Collection" class="w-full h-full object-cover rounded-lg" loading="lazy" />
            </figure>
            <div>
                <h2 id="featured-heading" class="text-4xl font-bold mb-4" style="color: var(--color-glacier-900)">Premium Book Collection</h2>
                <p class="text-lg mb-6" style="color: var(--color-glacier-700)">
                    Experience the ultimate in reading with our premium collection. Featuring leather-bound editions,
                    signed copies, and rare first editions.
                </p>
                <button disabled class="btn text-black px-8 py-3 rounded-lg font-semibold cursor-not-allowed bg-gray-400 border-gray-400">
                    Coming Soon
                </button>
            </div>
        </article>
    </div>
</section>

<SocialMedia />
<BottomFeatures />
