{
  "name": "@bookworm/clients",
  "version": "1.0.0",
  "description": "Frontend clients for BookWorm application",
  "author": "Nhan Nguyen <nguyenxuannhan407@gmail.com> (https://github.com/foxminchan)",
  "licenses": [
    {
      "type": "MIT",
      "url": "https://opensource.org/licenses/MIT"
    }
  ],
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/foxminchan/BookWorm.git",
    "directory": "src/Clients"
  },
  "bugs": {
    "url": "https://github.com/foxminchan/BookWorm/issues"
  },
  "homepage": "https://foxminchan.github.io/BookWorm/",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "e2e": "turbo run test:e2e",
    "boundaries": "turbo boundaries",
    "format": "prettier --write \"**/*.{ts,tsx,md,feature}\""
  },
  "lavamoat": {
    "allowScripts": {}
  },
  "devDependencies": {
    "@lavamoat/allow-scripts": "^5.0.2",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "prettier": "^3.8.3",
    "prettier-plugin-gherkin": "^3.1.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.9.16",
    "typescript": "6.0.3"
  },
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": ">=24.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
