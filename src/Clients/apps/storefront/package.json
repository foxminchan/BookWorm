{
  "name": "@bookworm/storefront",
  "version": "1.0.0",
  "type": "module",
  "description": "Customer-facing storefront application for BookWorm",
  "author": "Nhan Nguyen <nguyenxuannhan407@gmail.com> (https://github.com/foxminchan)",
  "licenses": [
    {
      "type": "MIT",
      "url": "https://opensource.org/licenses/MIT"
    }
  ],
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/foxminchan/BookWorm.git",
    "directory": "src/Clients/apps/storefront"
  },
  "bugs": {
    "url": "https://github.com/foxminchan/BookWorm/issues"
  },
  "homepage": "https://foxminchan.github.io/BookWorm/",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "bddgen": "npx bddgen",
    "bddgen:watch": "npx bddgen --watch",
    "bddgen:export": "npx bddgen export",
    "test:e2e": "npx bddgen && npx playwright test",
    "test:e2e:headed": "npx bddgen && npx playwright test --headed",
    "test:e2e:ui": "npx bddgen && npx playwright test --ui",
    "test:e2e:ci": "npx bddgen && npx playwright test --workers=4",
    "playwright:install": "playwright install --with-deps chromium",
    "playwright:install:all": "playwright install --with-deps",
    "allure:generate": "allure generate --output allure-report allure-results",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results"
  },
  "dependencies": {
    "@ag-ui/client": "^0.0.47",
    "@copilotkit/react-core": "1.54.0",
    "@copilotkit/react-ui": "1.54.0",
    "@copilotkit/runtime": "^1.54.0",
    "@hookform/resolvers": "^5.2.2",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.213.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/sdk-trace-node": "^2.6.0",
    "@t3-oss/env-nextjs": "^0.13.10",
    "@tanstack/react-query": "^5.94.5",
    "@workspace/api-client": "workspace:*",
    "@workspace/api-hooks": "workspace:*",
    "@workspace/mocks": "workspace:*",
    "@workspace/types": "workspace:*",
    "@workspace/ui": "workspace:*",
    "@workspace/utils": "workspace:*",
    "@workspace/validations": "workspace:*",
    "better-auth": "^1.5.5",
    "class-variance-authority": "^0.7.1",
    "classnames": "2.5.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "flags": "^4.0.5",
    "jotai": "^2.18.1",
    "jotai-tanstack-query": "^0.11.0",
    "lucide-react": "^0.577.0",
    "next": "16.2.0",
    "next-themes": "^0.4.6",
    "openai": "^6.32.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.5.0",
    "ts-pattern": "^5.9.0",
    "usehooks-ts": "3.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "@workspace/eslint-config": "workspace:^",
    "@workspace/typescript-config": "workspace:*",
    "allure": "^3.3.1",
    "allure-playwright": "^3.6.0",
    "allure-vitest": "^3.6.0",
    "eslint": "^10.1.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "happy-dom": "^20.8.4",
    "playwright-bdd": "^8.5.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
