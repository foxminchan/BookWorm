{
  "inputs": [
    {
      "id": "context7-api-key",
      "type": "promptString",
      "password": true,
      "description": "Enter your Context7 API Key"
    },
    {
      "id": "sonarqube-token",
      "type": "promptString",
      "password": true,
      "description": "Enter your SonarQube Token"
    }
  ],
  "servers": {
    "sequential-thinking": {
      "command": "bunx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    },
    "context7": {
      "type": "stdio",
      "command": "bunx",
      "args": [
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "${input:context7-api-key}"
      ]
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "aspire": {
      "type": "stdio",
      "command": "aspire",
      "args": ["mcp", "start"]
    },
    "drawio": {
      "command": "bunx",
      "args": ["@drawio/mcp"]
    },
    "sonarqube": {
      "command": "docker",
      "args": [
        "run",
        "--init",
        "--pull=always",
        "-i",
        "--rm",
        "-e",
        "SONARQUBE_TOKEN",
        "-e",
        "SONARQUBE_ORG",
        "mcp/sonarqube"
      ],
      "env": {
        "SONARQUBE_TOKEN": "${input:sonarqube-token}",
        "SONARQUBE_ORG": "foxminchan"
      }
    }
  }
}
