{
  "inputs": [
    {
      "id": "context7-api-key",
      "type": "promptString",
      "password": true,
      "description": "Enter your Context7 API Key"
    }
  ],
  "servers": {
    "sequential-thinking": {
      "command": "bunx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    },
    "context7": {
      "type": "stdio",
      "command": "bunx",
      "args": [
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "${input:context7-api-key}"
      ]
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "aspire": {
      "type": "stdio",
      "command": "aspire",
      "args": ["mcp", "start"]
    },
    "drawio": {
      "command": "bunx",
      "args": ["@drawio/mcp"]
    }
  }
}
